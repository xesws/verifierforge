#!/usr/bin/env bash
set -euo pipefail

REMOTE_ROOT=/workspace/verifierforge
REPO_URL="${VF_REPO_URL:-git@github.com:xesws/verifierforge.git}"
REMOTE_KEY_RESTORE='if [ -f /workspace/.ssh/id_ed25519 ]; then install -d -m 700 ~/.ssh; install -m 600 /workspace/.ssh/id_ed25519 ~/.ssh/id_ed25519; [ ! -f /workspace/.ssh/id_ed25519.pub ] || install -m 644 /workspace/.ssh/id_ed25519.pub ~/.ssh/id_ed25519.pub; [ ! -f /workspace/.ssh/known_hosts ] || install -m 600 /workspace/.ssh/known_hosts ~/.ssh/known_hosts; fi;'

usage() {
  echo "usage: vf {bootstrap|train <job> <cfg>|watch <job>|logs <job>|status|kill <job>|model <job>}" >&2
  exit 2
}

job_arg() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] || usage
}

cfg_arg() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._/@+=:-]+$ ]] || usage
}

repo_arg() {
  [[ "$1" =~ ^[A-Za-z0-9._/@+=:-]+$ ]] || usage
}

case "${1:-}" in
  bootstrap)
    repo_arg "$REPO_URL"
    ssh runpod "set -e; if ! command -v git >/dev/null; then apt-get update && DEBIAN_FRONTEND=noninteractive apt-get install -y git; fi; mkdir -p /workspace; $REMOTE_KEY_RESTORE if [ -d $REMOTE_ROOT/.git ]; then git -C $REMOTE_ROOT pull --ff-only; else git clone $REPO_URL $REMOTE_ROOT; fi; cd $REMOTE_ROOT && bash trainer/bootstrap.sh"
    ;;
  train)
    job_arg "${2:-}"
    job="$2"
    cfg="${3:-}"
    cfg_arg "$cfg"
    ssh runpod "$REMOTE_KEY_RESTORE cd $REMOTE_ROOT && git pull --ff-only && mkdir -p runs/$job && tmux new-session -d -s $job 'bash trainer/launch.sh $job $cfg 2>&1 | tee runs/$job/train.log'"
    ;;
  watch)
    job_arg "${2:-}"
    job="$2"
    mkdir -p "runs/$job"
    while true; do
      rsync -az --exclude='*.safetensors' --exclude='ckpt/' --exclude='.verl-staging/' "runpod:$REMOTE_ROOT/runs/$job/" "runs/$job/"
      sleep 2
    done
    ;;
  logs)
    job_arg "${2:-}"
    ssh runpod "tail -n 100 -f $REMOTE_ROOT/runs/$2/train.log"
    ;;
  status)
    ssh runpod "tmux list-sessions 2>/dev/null || true; nvidia-smi"
    ;;
  kill)
    job_arg "${2:-}"
    ssh runpod "tmux kill-session -t $2"
    ;;
  model)
    job_arg "${2:-}"
    mkdir -p "models/$2"
    rsync -az "runpod:$REMOTE_ROOT/runs/$2/artifacts/final/" "models/$2/"
    ;;
  *)
    usage
    ;;
esac
