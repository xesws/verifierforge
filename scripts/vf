#!/usr/bin/env bash
set -euo pipefail

REMOTE_ROOT=/workspace/verifierforge
REMOTE_PYTHON="$REMOTE_ROOT/.venv/bin/python"
REPO_URL="${VF_REPO_URL:-git@github.com:xesws/verifierforge.git}"
REMOTE_KEY_RESTORE='if [ -f /workspace/.ssh/id_ed25519 ]; then install -d -m 700 ~/.ssh; install -m 600 /workspace/.ssh/id_ed25519 ~/.ssh/id_ed25519; [ ! -f /workspace/.ssh/id_ed25519.pub ] || install -m 644 /workspace/.ssh/id_ed25519.pub ~/.ssh/id_ed25519.pub; [ ! -f /workspace/.ssh/known_hosts ] || install -m 600 /workspace/.ssh/known_hosts ~/.ssh/known_hosts; fi;'

usage() {
  echo "usage: vf {bootstrap|train <job> <cfg>|watch <job>|logs <job>|status|kill <job>|model <job>}" >&2
  exit 2
}

job_arg() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._-]+$ ]] || usage
}

cfg_arg() {
  [[ "${1:-}" =~ ^[A-Za-z0-9._/@+=:-]+$ ]] || usage
}

repo_arg() {
  [[ "$1" =~ ^[A-Za-z0-9._/@+=:-]+$ ]] || usage
}

restore_remote_key() {
  ssh runpod "$REMOTE_KEY_RESTORE"
}

bootstrap_remote() {
  local repo_url="$1"

  ssh runpod bash -s -- "$REMOTE_ROOT" "$repo_url" <<'REMOTE'
set -euo pipefail

root="$1"
repo_url="$2"
workspace=$(dirname "$root")
session="vf-bootstrap"

if [[ -f "$workspace/.ssh/id_ed25519" ]]; then
  install -d -m 700 ~/.ssh
  install -m 600 "$workspace/.ssh/id_ed25519" ~/.ssh/id_ed25519
  [[ ! -f "$workspace/.ssh/id_ed25519.pub" ]] || \
    install -m 644 "$workspace/.ssh/id_ed25519.pub" ~/.ssh/id_ed25519.pub
  [[ ! -f "$workspace/.ssh/known_hosts" ]] || \
    install -m 600 "$workspace/.ssh/known_hosts" ~/.ssh/known_hosts
fi

packages=()
for command in git tmux; do
  command -v "$command" >/dev/null 2>&1 || packages+=("$command")
done
if ((${#packages[@]})); then
  apt-get update
  DEBIAN_FRONTEND=noninteractive apt-get install -y "${packages[@]}"
fi

mkdir -p "$workspace"
if [[ -d "$root/.git" ]]; then
  git -C "$root" pull --ff-only
else
  git clone "$repo_url" "$root"
fi

cd "$root"
provisioning_dir="runs/provisioning"
status_file="$provisioning_dir/runtime-install.status"
log_file="$provisioning_dir/runtime-install.log"
mkdir -p "$provisioning_dir"

if tmux has-session -t "$session" 2>/dev/null; then
  echo "vf bootstrap: installation already running in tmux session $session; waiting"
else
  rm -f "$status_file"
  tmux new-session -d -s "$session" \
    "cd \"$root\" && exec bash trainer/bootstrap.sh"
  echo "vf bootstrap: installation started in tmux session $session; waiting"
fi

while tmux has-session -t "$session" 2>/dev/null; do
  sleep 2
done

for _ in {1..20}; do
  [[ -f "$status_file" ]] && break
  sleep 0.1
done

if [[ ! -f "$status_file" ]]; then
  echo "vf bootstrap failed: missing $status_file after tmux exit" >&2
  [[ ! -f "$log_file" ]] || tail -n 30 "$log_file" >&2
  exit 1
fi

if ! grep -qx 'state=success' "$status_file"; then
  echo "vf bootstrap failed: runtime installation did not complete successfully" >&2
  cat "$status_file" >&2
  [[ ! -f "$log_file" ]] || tail -n 30 "$log_file" >&2
  exit 1
fi

cat "$status_file"
REMOTE
}

start_remote_job() {
  local job="$1"
  local cfg="$2"

  restore_remote_key
  ssh runpod bash -s -- "$REMOTE_ROOT" "$REMOTE_PYTHON" "$job" "$cfg" <<'REMOTE'
set -euo pipefail

root="$1"
python="$2"
job="$3"
cfg="$4"

cd "$root"
git pull --ff-only
"$python" -c 'import scripts.gate_a'
mkdir -p "runs/$job"
rm -f "runs/$job/pgid"
tmux new-session -d -s "$job" \
  "cd \"$root\" && exec setsid bash -c 'printf \"%s\\n\" \"\$\$\" > \"runs/$job/pgid\"; exec bash trainer/launch.sh \"$job\" \"$cfg\"' 2>&1 | tee \"runs/$job/train.log\""

for _ in {1..20}; do
  [[ -s "runs/$job/pgid" ]] && exit 0
  sleep 0.1
done

tmux kill-session -t "$job" 2>/dev/null || true
echo "vf train failed: $job did not publish a PGID marker" >&2
exit 1
REMOTE
}

stop_remote_job() {
  local job="$1"

  ssh runpod bash -s -- "$REMOTE_ROOT" "$job" <<'REMOTE'
set -euo pipefail

root="$1"
job="$2"
cd "$root"

tmux kill-session -t "$job" 2>/dev/null || true
pgid_file="runs/$job/pgid"
if [[ -s "$pgid_file" ]]; then
  read -r pgid < "$pgid_file"
  if [[ "$pgid" =~ ^[1-9][0-9]*$ ]]; then
    if kill -0 -- "-$pgid" 2>/dev/null; then
      kill -TERM -- "-$pgid" 2>/dev/null || true
      for _ in {1..5}; do
        kill -0 -- "-$pgid" 2>/dev/null || break
        sleep 1
      done
      kill -0 -- "-$pgid" 2>/dev/null && kill -KILL -- "-$pgid" 2>/dev/null || true
    fi
  else
    echo "vf kill: invalid PGID marker for $job" >&2
    exit 1
  fi
else
  echo "vf kill: no PGID marker for $job; using Ray fallback" >&2
fi

if [[ -x "$root/.venv/bin/ray" ]]; then
  "$root/.venv/bin/ray" stop --force || true
else
  ray stop --force || true
fi

compute_apps="$(nvidia-smi --query-compute-apps=pid,process_name,used_memory --format=csv,noheader 2>/dev/null || true)"
gpu_memory="$(nvidia-smi --query-gpu=memory.used --format=csv,noheader,nounits | awk '{sum += $1} END {print sum + 0}')"
if [[ -n "${compute_apps//[[:space:]]/}" ]] || (( gpu_memory != 0 )); then
  echo "vf kill failed: GPU still has $gpu_memory MiB allocated" >&2
  nvidia-smi >&2
  exit 1
fi

printf 'vf kill complete: %s (GPU memory: %s MiB)\n' "$job" "$gpu_memory"
REMOTE
}

case "${1:-}" in
  bootstrap)
    repo_arg "$REPO_URL"
    restore_remote_key
    bootstrap_remote "$REPO_URL"
    ;;
  train)
    job_arg "${2:-}"
    job="$2"
    cfg="${3:-}"
    cfg_arg "$cfg"
    start_remote_job "$job" "$cfg"
    ;;
  watch)
    job_arg "${2:-}"
    job="$2"
    mkdir -p "runs/$job"
    while true; do
      rsync -az --exclude='*.safetensors' --exclude='ckpt/' --exclude='.verl-staging/' --exclude='evidence/failed-staging/' "runpod:$REMOTE_ROOT/runs/$job/" "runs/$job/"
      sleep 2
    done
    ;;
  logs)
    job_arg "${2:-}"
    ssh runpod "tail -n 100 -f $REMOTE_ROOT/runs/$2/train.log"
    ;;
  status)
    ssh runpod "tmux list-sessions 2>/dev/null || true; nvidia-smi"
    ;;
  kill)
    job_arg "${2:-}"
    stop_remote_job "$2"
    ;;
  model)
    job_arg "${2:-}"
    mkdir -p "models/$2"
    rsync -az "runpod:$REMOTE_ROOT/runs/$2/artifacts/final/" "models/$2/"
    ;;
  *)
    usage
    ;;
esac
